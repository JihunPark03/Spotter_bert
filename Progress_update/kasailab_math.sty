% 各種の数学記号や数式表現 (mathbb etc.)
\usepackage{amsmath}
\usepackage{amssymb}% Hadamard Product (\circledast)
\usepackage{amsfonts}
\usepackage{amsthm}

% vector
\def\vec#1{\mbox{\boldmath $#1$}}
\def\vx{\vec{x}}
\def\vy{\vec{y}}
\def\vz{\vec{z}}
\def\va{\vec{a}}
\def\vb{\vec{b}}
\def\vc{\vec{c}}
\def\vd{\vec{d}}
\def\ve{\vec{e}}
\def\vf{\vec{f}}
\def\vg{\vec{g}}
\def\vu{\vec{u}}
\def\vv{\vec{v}}
\def\vr{\vec{r}}
\def\vw{\vec{w}}
\def\vlam{\vec{\lambda}}
\def\vmu{\vec{\mu}}
\def\vnu{\vec{\nu}}

% matrix
\def\mat#1{\mbox{\bf #1}}   

% norm
\def\norm#1{\mbox{$\left\|#1\right\|$}}
% l1,l2-norm
\def\L#1{\mbox{$\ell_{#1}$}}	

% tensor
\DeclareMathAlphabet\mathbfcal{OMS}{cmsy}{b}{d}

% min, max
\renewcommand{\min}{\mathop{\rm minimize}\limits}
\renewcommand{\max}{\mathop{\rm maximize}\limits}
\newcommand{\argmax}{\mathop{\rm arg~max}\limits}
\newcommand{\argmin}{\mathop{\rm arg~min}\limits}
\newcommand{\defmax}{\mathop{\rm max}\limits}
\newcommand{\defmin}{\mathop{\rm min}\limits}

% 
\def\R{\mbox{$\mathbb{R}$} }   
\def\E{\mbox{$\mathbb{E}$} } 
\def\V{\mbox{$\mathbb{V}$} }     
\def\W{\mbox{$\mathbb{W}$} }
\def\K{\mbox{$\mathbb{K}$} }
\def\S{\mbox{$\mathbb{S}$} }   
\def\C{\mbox{$\mathcal{C}$} }   

% Riemannian gradient and Hessian
\newcommand{\gradf}{{\rm grad} f}
\newcommand{\hessf}{{\rm Hess} f}
\newcommand{\gradh}{{\rm grad} h}
\newcommand{\hessh}{{\rm Hess} h}
\newcommand{\grad}{{\rm grad}}



% algorithm
\usepackage{algorithmic,algorithm}

% theorem
\newtheorem{Def}{Definition}[section]
\newtheorem{Thm}[Def]{Theorem}
\newtheorem{Cor}[Def]{Corollary}
\newtheorem{Lem}[Def]{Lemma}
\newtheorem{Prop}[Def]{Proposition}
\newtheorem{Ex}[Def]{Example}
\newtheorem{Remark}[Def]{Remark}


